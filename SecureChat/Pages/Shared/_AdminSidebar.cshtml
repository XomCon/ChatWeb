@{
    var path = Context.Request.Path.Value?.ToLower() ?? "";

    string Active(string keyword)
    {
        return path.Contains(keyword.ToLower()) ? "admin-sidebar__link--active" : "";
    }
}

<aside class="admin-sidebar" style="animation: fadeInLeft 0.8s ease forwards;">
    <div class="admin-sidebar__top">
        <div class="admin-sidebar__brand">
            <div class="admin-sidebar__brand-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
                <div class="admin-sidebar__brand-title">SOC Console</div>
                <div class="admin-sidebar__brand-subtitle">Level 5 Access</div>
            </div>
        </div>
    </div>

    <nav class="admin-sidebar__nav">
        <a asp-page="/Admin/Index" class="admin-sidebar__link @Active("/admin/index")">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            <span>Tổng quan Dashboard</span>
        </a>

        <a asp-page="/Admin/Users" class="admin-sidebar__link @Active("/admin/users")">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span>Quản lý Identity Nodes</span>
        </a>

        <a asp-page="/Admin/Groups" class="admin-sidebar__link @Active("/admin/groups")">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
            <span>Quản lý Clusters</span>
        </a>

        <a asp-page="/Admin/Logs" class="admin-sidebar__link @Active("/admin/logs")">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 9h8"/><path d="M8 13h6"/></svg>
            <span>Audit Logs & Forensic</span>
        </a>

        <div style="margin: 20px 0; border-top: 1px solid var(--glass-border);"></div>

        <a asp-page="/Index" class="admin-sidebar__link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span>Quay lại System</span>
        </a>

        <a asp-page="/Account/Logout" class="admin-sidebar__link admin-sidebar__link--logout">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            <span>Terminate Session</span>
        </a>
    </nav>
</aside>

<style>
    @@keyframes fadeInLeft {
        from { opacity: 0; transform: translateX(-30px); }
        to { opacity: 1; transform: translateX(0); }
    }
</style>