<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SecureChat</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="bg-orb orb-1"></div>
    <div class="bg-orb orb-2"></div>

    @{
        var userId = Context.Session.GetString("UserId");
        var fullName = Context.Session.GetString("FullName");
        var email = Context.Session.GetString("Email");
        var role = Context.Session.GetString("Role");
        var path = Context.Request.Path.Value?.ToLower() ?? "";
        bool isLoggedIn = !string.IsNullOrEmpty(userId);

        string IsActive(string keyword)
        {
            return path.Contains(keyword.ToLower()) ? "active" : "";
        }
    }

    @if (isLoggedIn)
    {
        <div class="app-shell">
            <aside class="app-sidebar">
                <div class="brand-box">
                    <div class="brand-dot"></div>
                    <div>
                        <div class="brand-title">SecureChat</div>
                        <div class="brand-subtitle">Aurora System</div>
                    </div>
                </div>

                <div class="sidebar-user">
                    <div class="sidebar-avatar">
                        @(string.IsNullOrWhiteSpace(fullName) ? "U" : fullName.Substring(0, 1).ToUpper())
                    </div>
                    <div class="sidebar-user-info">
                        <div class="sidebar-user-name">@fullName</div>
                        <div class="sidebar-user-role">@role</div>
                    </div>
                </div>

                <nav class="sidebar-nav">
                    <a asp-page="/Index" class="sidebar-link @IsActive("/index")">
                        <span class="sidebar-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                        </span>
                        <span>Trang chủ</span>
                    </a>

                    <div class="sidebar-section-title">Cá nhân</div>
                    <a asp-page="/Account/Profile" class="sidebar-link @IsActive("/account/profile")">
                        <span class="sidebar-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        </span>
                        <span>Hồ sơ</span>
                    </a>

                    <a asp-page="/Account/ChangePassword" class="sidebar-link @IsActive("/account/changepassword")">
                        <span class="sidebar-icon">
                           <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        </span>
                        <span>Bảo mật</span>
                    </a>

                    <div class="sidebar-section-title">Kết nối</div>
                    <a asp-page="/Friends/Index" class="sidebar-link @IsActive("/friends/index")">
                        <span class="sidebar-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        </span>
                        <span>Bạn bè</span>
                    </a>

                    <a asp-page="/Chat/Recent" class="sidebar-link @IsActive("/chat/recent")">
                        <span class="sidebar-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        </span>
                        <span>Trò chuyện</span>
                    </a>

                    <a asp-page="/Groups/Index" class="sidebar-link @IsActive("/groups/index")">
                        <span class="sidebar-icon">
                           <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/></svg>
                        </span>
                        <span>Nhóm chat</span>
                    </a>

                    @if (role == "Admin")
                    {
                        <div class="sidebar-section-title">Hệ thống</div>
                        <a asp-page="/Admin/Index" class="sidebar-link @IsActive("/admin/index")">
                            <span class="sidebar-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                            </span>
                            <span>Admin Console</span>
                        </a>

                        <a asp-page="/Admin/Logs" class="sidebar-link @IsActive("/admin/logs")">
                            <span class="sidebar-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="12" x2="3" y2="12"/><line x1="21" y1="18" x2="3" y2="18"/></svg>
                            </span>
                            <span>Nhật ký</span>
                        </a>
                    }
                </nav>

                <a asp-page="/Account/Logout" class="sidebar-link" style="margin-top: auto; color: #fca5a5;">
                    <span class="sidebar-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    </span>
                    <span>Đăng xuất</span>
                </a>
            </aside>

            <main class="app-main">
                <header class="app-topbar">
                    <div>
                        <h1 class="app-page-title">@ViewData["Title"]</h1>
                        <p class="app-page-subtitle">Hệ thống liên lạc đa kênh bảo mật</p>
                    </div>
                </header>

                <div class="app-content">
                    @RenderBody()
                </div>
            </main>
        </div>
    }
    else
    {
        <div class="guest-shell">
            <nav class="guest-navbar">
                <div class="guest-brand">SecureChat <span style="color:var(--emerald)">Aurora</span></div>
                <div class="guest-nav-links">
                    <a asp-page="/Index">Trang chủ</a>
                    <a asp-page="/Account/Login">Đăng nhập</a>
                    <a asp-page="/Account/Register" class="btn btn-primary" style="padding: 8px 16px;">Đăng ký</a>
                </div>
            </nav>

            <main class="guest-main">
                @RenderBody()
            </main>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>