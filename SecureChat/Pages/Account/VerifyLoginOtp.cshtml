@page
@model SecureChat.Pages.Account.VerifyLoginOtpModel
@{
    ViewData["Title"] = "Xác thực lớp bảo mật";
}

<div class="page-box" style="animation: fadeInUp 0.8s ease forwards; max-width: 450px; margin: 0 auto; min-height: calc(100vh - 200px); display: flex; flex-direction: column; justify-content: center;">
    <div style="text-align: center; margin-bottom: 32px;">
        <div style="width: 64px; height: 64px; border-radius: 20px; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; color: var(--emerald-glow);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h2 style="font-size: 24px; margin: 0;">Xác thực OTP</h2>
        <p style="color: var(--text-muted); font-size: 14px; margin-top: 8px;">
            Mã xác thực đã được gửi tới:<br/>
            <strong style="color: var(--text-secondary);">@Model.Email</strong>
        </p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" style="border-radius: 12px; margin-bottom: 24px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @Model.ErrorMessage
        </div>
    }

    <div class="glass-card" style="padding: 32px; border-radius: 24px;">
        <form method="post">
            <div class="form-group" style="margin-bottom: 32px;">
                <label asp-for="Input.OtpCode" class="form-label" style="text-align: center; display: block; margin-bottom: 16px; letter-spacing: 0.05em; text-transform: uppercase; font-size: 11px; font-weight: 800;">Nhập mã 6 chữ số</label>
                <div style="position: relative;">
                    <input asp-for="Input.OtpCode" class="form-control" style="text-align: center; font-size: 24px; letter-spacing: 0.5em; height: 60px; font-weight: 900; background: rgba(0,0,0,0.2); border-color: rgba(255,255,255,0.05);" placeholder="••••••" maxlength="6" autocomplete="one-time-code" />
                </div>
                <span asp-validation-for="Input.OtpCode" class="text-danger" style="text-align: center; display: block; margin-top: 8px;"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100" style="padding: 16px; font-size: 14px; text-transform: uppercase; letter-spacing: 0.1em;">
                Xác nhận danh tính
            </button>
        </form>
    </div>

    <div style="text-align: center; margin-top: 32px;">
        <p style="font-size: 13px; color: var(--text-muted);">
            Không nhận được mã? <a href="#" style="color: var(--emerald-glow); font-weight: 800; text-decoration: none;">Gửi lại yêu cầu</a>
        </p>
        <a asp-page="/Account/Login" style="font-size: 12px; color: var(--text-muted); text-decoration: none; display: inline-flex; align-items: center; gap: 6px; margin-top: 16px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            Quay lại đăng nhập
        </a>
    </div>
</div>

<style>
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .form-control:focus {
        background: rgba(0,0,0,0.3) !important;
        border-color: var(--emerald) !important;
        box-shadow: 0 0 15px rgba(16, 185, 129, 0.1);
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}