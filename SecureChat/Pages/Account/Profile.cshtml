@page
@model SecureChat.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    var avatarText = !string.IsNullOrWhiteSpace(Model.Input.FullName)
        ? Model.Input.FullName.Substring(0, 1).ToUpper()
        : "U";
}

<div class="page-box">
    <div class="profile-header">
        @if (!string.IsNullOrWhiteSpace(Model.Input.AvatarUrl))
        {
            <img src="@Model.Input.AvatarUrl" alt="Avatar" class="profile-avatar" />
        }
        else
        {
            <div class="profile-avatar-placeholder">@avatarText</div>
        }

        <div class="profile-meta">
            <h2>@Model.Input.FullName</h2>
            <p>@Model.Email</p>
            <p>
                <span class="badge-soft badge-info">@Model.Role</span>
            </p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div class="info-grid">
        <div class="info-card">
            <span class="label">Email</span>
            <span class="value">@Model.Email</span>
        </div>
        <div class="info-card">
            <span class="label">Vai trò</span>
            <span class="value">@Model.Role</span>
        </div>
        <div class="info-card">
            <span class="label">Ngày tạo tài khoản</span>
            <span class="value">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
        </div>
    </div>

    <form method="post">
        <div class="mb-3">
            <label asp-for="Input.FullName" class="form-label"></label>
            <input asp-for="Input.FullName" class="form-control" placeholder="Nhập họ tên" />
            <span asp-validation-for="Input.FullName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.PhoneNumber" class="form-label"></label>
            <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Nhập số điện thoại" />
            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Input.AvatarUrl" class="form-label"></label>
            <input asp-for="Input.AvatarUrl" class="form-control" placeholder="Dán link ảnh đại diện" />
            <span asp-validation-for="Input.AvatarUrl" class="text-danger"></span>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary">Cập nhật hồ sơ</button>
            <a asp-page="/Account/ChangePassword" class="btn btn-outline-light">Đổi mật khẩu</a>
            <a asp-page="/Account/ForgotPassword" class="btn btn-outline-light">Quên mật khẩu</a>
            <a asp-page="/Index" class="btn btn-outline-light">Về trang chủ</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}