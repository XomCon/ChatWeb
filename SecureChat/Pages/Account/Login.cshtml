@page
@model SecureChat.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div style="min-height: calc(100vh - 80px); display: flex; align-items: center; justify-content: center; padding: 24px;">
    <div class="glass-card" style="width: 100%; maxWidth: 1000px; display: grid; grid-template-columns: 1fr 1fr; border-radius: 40px; overflow: hidden; animation: fadeInUp 0.8s ease forwards;">
        
        <!-- ── Left: Form Panel ── -->
        <div style="padding: 60px 50px; background: rgba(10, 12, 16, 0.4);">
            <div style="margin-bottom: 40px;">
                <div class="badge-soft badge-emerald" style="margin-bottom: 16px;">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    Secure Portal v4.2
                </div>
                <h1 style="font-size: 32px; margin-bottom: 8px;">Đăng nhập</h1>
                <p style="color: var(--text-secondary); font-size: 14px; line-height: 1.6;">
                    Truy cập vào hệ thống SecureChat Aurora. Danh tính của bạn sẽ được xác thực qua lớp bảo mật Matrix.
                </p>
            </div>

            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success" style="font-size: 13px; border-radius: 12px; margin-bottom: 24px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    @Model.SuccessMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger" style="font-size: 13px; border-radius: 12px; margin-bottom: 24px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                <div class="form-group">
                    <label asp-for="Input.Email" class="form-label">Email Address</label>
                    <div style="position: relative;">
                        <span style="position: absolute; left: 16px; top: 16px; color: var(--text-muted);">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        </span>
                        <input asp-for="Input.Email" class="form-control" style="padding-left: 48px;" placeholder="name@securechat.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-group" style="margin-bottom: 32px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                        <label asp-for="Input.Password" class="form-label" style="margin: 0;">Password</label>
                        <a asp-page="/Account/ForgotPassword" style="font-size: 12px; font-weight: 700; color: var(--text-muted);">Quên mật khẩu?</a>
                    </div>
                    <div style="position: relative;">
                        <span style="position: absolute; left: 16px; top: 16px; color: var(--text-muted);">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        </span>
                        <input asp-for="Input.Password" type="password" class="form-control" style="padding-left: 48px;" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100" style="padding: 16px; font-size: 15px; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 24px;">
                    Xác thực & Truy cập
                </button>
            </form>

            <div style="text-align: center; font-size: 14px; color: var(--text-secondary);">
                Chưa có tài khoản? <a asp-page="/Account/Register" style="font-weight: 800; color: var(--emerald-glow);">Khởi tạo ngay</a>
            </div>
        </div>

        <!-- ── Right: Info Panel ── -->
        <div style="padding: 60px 48px; background: radial-gradient(circle at center, rgba(16, 185, 129, 0.15) 0%, rgba(10, 12, 16, 0.95) 100%); display: flex; flex-direction: column; justify-content: center; border-left: 1px solid var(--glass-border); position: relative; overflow: hidden;">
            <div style="position: absolute; top: -100px; right: -100px; width: 300px; height: 300px; background: var(--emerald); filter: blur(150px); opacity: 0.1;"></div>
            
            <div style="position: relative; z-index: 1;">
                <div class="badge-soft badge-emerald" style="margin-bottom: 24px;">Security Protocol active</div>
                <h2 style="font-size: 28px; margin-bottom: 32px; line-height: 1.2;">Bảo mật đa lớp<br/><span style="color: var(--emerald-glow);">Xác thực 2-Step OTP</span></h2>
                
                <div style="display: flex; flex-direction: column; gap: 32px;">
                    <div style="display: flex; gap: 16px; align-items: flex-start;">
                        <div style="width: 40px; height: 40px; border-radius: 12px; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--emerald)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        </div>
                        <div>
                            <h4 style="font-size: 16px; margin-bottom: 4px;">Matrix Protection</h4>
                            <p style="color: var(--text-muted); font-size: 13px; margin: 0;">Mật khẩu của bạn được băm bằng thuật toán Argon2id chống brute-force cực mạnh.</p>
                        </div>
                    </div>

                    <div style="display: flex; gap: 16px; align-items: flex-start;">
                        <div style="width: 40px; height: 40px; border-radius: 12px; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#38bdf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                        </div>
                        <div>
                            <h4 style="font-size: 16px; margin-bottom: 4px;">Smart OTP detection</h4>
                            <p style="color: var(--text-muted); font-size: 13px; margin: 0;">Hệ thống tự động phát hiện thiết bị lạ và gửi mã xác thực về Gmail ngay lập tức.</p>
                        </div>
                    </div>

                    <div style="display: flex; gap: 16px; align-items: flex-start;">
                        <div style="width: 40px; height: 40px; border-radius: 12px; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                        </div>
                        <div>
                            <h4 style="font-size: 16px; margin-bottom: 4px;">Session Control</h4>
                            <p style="color: var(--text-muted); font-size: 13px; margin: 0;">Quản lý phiên đăng nhập chặt chẽ, tự động hủy phiên khi phát hiện dấu hiệu bất thường.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div style="margin-top: auto; padding-top: 40px;">
                <div style="display: flex; align-items: center; gap: 12px; opacity: 0.5;">
                    <div style="width: 8px; height: 8px; border-radius: 50%; background: var(--emerald); box-shadow: 0 0 10px var(--emerald);"></div>
                    <span style="font-size: 10px; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase;">AES-256 Link Encryption Active</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @@media (max-width: 900px) {
        .glass-card { grid-template-columns: 1fr !important; border-radius: 24px !important; }
        div[style*="background: radial-gradient"] { display: none !important; }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}