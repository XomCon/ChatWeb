@page
@model SecureChat.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Khôi phục quyền truy cập";
}

<div style="min-height: calc(100vh - 120px); display: flex; align-items: center; justify-content: center; padding: 24px;">
    <div class="glass-card" style="width: 100%; maxWidth: 900px; display: grid; grid-template-columns: 1.1fr 0.9fr; border-radius: 40px; overflow: hidden; animation: fadeInUp 0.8s ease forwards;">
        
        <!-- ── Left: Form Panel ── -->
        <div style="padding: 50px; background: rgba(10, 12, 16, 0.4);">
            <div style="margin-bottom: 32px;">
                <div class="badge-soft badge-danger" style="margin-bottom: 16px;">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.778-7.778zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3L15.5 7.5z"/></svg>
                    Account Recovery Protocol
                </div>
                <h1 style="font-size: 28px; margin-bottom: 8px;">Quên mật khẩu?</h1>
                <p style="color: var(--text-secondary); font-size: 13px; line-height: 1.6;">
                    Thiết lập lại mật mã bảo mật cho tài khoản của bạn. Sau khi gửi, hệ thống sẽ yêu cầu xác thực OTP qua Gmail.
                </p>
            </div>

            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success" style="font-size: 13px; border-radius: 12px; margin-bottom: 24px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><polyline points="20 6 9 17 4 12"/></svg>
                    @Model.SuccessMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger" style="font-size: 13px; border-radius: 12px; margin-bottom: 24px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                <div class="form-group" style="margin-bottom: 24px;">
                    <label asp-for="Input.Email" class="form-label">Gmail Address</label>
                    <div style="position: relative;">
                        <span style="position: absolute; left: 16px; top: 16px; color: var(--text-muted);">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        </span>
                        <input asp-for="Input.Email" class="form-control" style="padding-left: 48px;" placeholder="name@gmail.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 32px;">
                    <div class="form-group" style="margin-bottom: 0;">
                        <label asp-for="Input.NewPassword" class="form-label">New Password</label>
                        <input asp-for="Input.NewPassword" type="password" class="form-control" placeholder="••••••••" />
                        <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                    </div>
                    <div class="form-group" style="margin-bottom: 0;">
                        <label asp-for="Input.ConfirmNewPassword" class="form-label">Confirm</label>
                        <input asp-for="Input.ConfirmNewPassword" type="password" class="form-control" placeholder="••••••••" />
                        <span asp-validation-for="Input.ConfirmNewPassword" class="text-danger"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100" style="padding: 16px; font-size: 14px; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 24px;">
                    Yêu cầu đặt lại mật mã
                </button>
            </form>

            <div style="text-align: center; font-size: 14px; color: var(--text-secondary);">
                Nhớ mật khẩu? <a asp-page="/Account/Login" style="font-weight: 800; color: var(--emerald-glow);">Quay lại đăng nhập</a>
            </div>
        </div>

        <!-- ── Right: Showcase Panel ── -->
        <div style="padding: 50px 40px; background: radial-gradient(circle at center, rgba(239, 68, 68, 0.08) 0%, rgba(10, 12, 16, 0.95) 100%); display: flex; flex-direction: column; justify-content: center; border-left: 1px solid var(--glass-border); position: relative; overflow: hidden;">
            <div style="position: absolute; top: -50px; right: -50px; width: 250px; height: 250px; background: #ef4444; filter: blur(120px); opacity: 0.1;"></div>
            
            <div style="position: relative; z-index: 1;">
                <h2 style="font-size: 24px; margin-bottom: 40px; line-height: 1.3;">Khôi phục định danh<br/><span style="color: #fca5a5;">An toàn & Tức thì</span></h2>
                
                <div style="display: flex; flex-direction: column; gap: 28px;">
                    <div style="display: flex; gap: 16px;">
                        <div style="width: 32px; height: 32px; border-radius: 50%; background: var(--bg-accent); border: 1px solid var(--glass-border-bright); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 900; color: #fca5a5; flex-shrink: 0; margin-top: 4px;">01</div>
                        <div>
                            <h4 style="font-size: 15px; margin-bottom: 4px;">Xác minh sở hữu</h4>
                            <p style="color: var(--text-muted); font-size: 12px; margin: 0;">Sử dụng Gmail đã đăng ký để bắt đầu quá trình chiếm lại quyền kiểm soát Node.</p>
                        </div>
                    </div>

                    <div style="display: flex; gap: 16px;">
                        <div style="width: 32px; height: 32px; border-radius: 50%; background: var(--bg-accent); border: 1px solid var(--glass-border-bright); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 900; color: #fca5a5; flex-shrink: 0; margin-top: 4px;">02</div>
                        <div>
                            <h4 style="font-size: 15px; margin-bottom: 4px;">Kiểm tra tin nhắn</h4>
                            <p style="color: var(--text-muted); font-size: 12px; margin: 0;">Mã OTP khẩn cấp sẽ được gửi tới inbox của bạn trong giây lát.</p>
                        </div>
                    </div>

                    <div style="display: flex; gap: 16px;">
                        <div style="width: 32px; height: 32px; border-radius: 50%; background: var(--bg-accent); border: 1px solid var(--glass-border-bright); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 900; color: #fca5a5; flex-shrink: 0; margin-top: 4px;">03</div>
                        <div>
                            <h4 style="font-size: 15px; margin-bottom: 4px;">Tái thiết mật mã</h4>
                            <p style="color: var(--text-muted); font-size: 12px; margin: 0;">Áp dụng mật mã mới với tiêu chuẩn bảo mật Aurora cho tài khoản của bạn.</p>
                        </div>
                    </div>
                </div>

                <div style="margin-top: 60px; padding: 20px; border-radius: 20px; background: rgba(0,0,0,0.2); border: 1px solid rgba(239,68,68,0.2);">
                    <div style="display: flex; gap: 12px; align-items: center; margin-bottom: 12px;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fca5a5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        <span style="font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: #fca5a5;">Emergency Note</span>
                    </div>
                    <p style="color: var(--text-muted); font-size: 12px; margin: 0; line-height: 1.5;">
                        Nếu bạn không nhận được mã OTP, vui lòng kiểm tra thư mục Spam hoặc liên hệ với quản trị viên hệ thống.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @@media (max-width: 900px) {
        .glass-card { grid-template-columns: 1fr !important; border-radius: 24px !important; }
        div[style*="background: radial-gradient"] { display: none !important; }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}