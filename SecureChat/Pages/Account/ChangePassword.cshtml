@page
@model SecureChat.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Cấu hình mật mã mới";
}

<div class="page-box" style="animation: fadeInUp 0.8s ease forwards; max-width: 500px; margin: 0 auto;">
    <div style="margin-bottom: 32px; text-align: center;">
        <div class="badge-soft badge-warning" style="margin-bottom: 16px;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Security Protocol Update
        </div>
        <h2 style="font-size: 28px; margin: 0;">Đổi mật khẩu</h2>
        <p style="color: var(--text-muted); font-size: 14px; margin-top: 8px;">Thiết lập lại lớp mật mã bảo vệ cho Node định danh của bạn.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success" style="border-radius: 12px; margin-bottom: 24px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><polyline points="20 6 9 17 4 12"/></svg>
            @Model.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" style="border-radius: 12px; margin-bottom: 24px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @Model.ErrorMessage
        </div>
    }

    <div class="glass-card" style="padding: 32px; border-radius: 24px;">
        <form method="post">
            <div class="form-group" style="margin-bottom: 20px;">
                <label asp-for="Input.CurrentPassword" class="form-label">Mật khẩu hiện tại</label>
                <div style="position: relative;">
                    <span style="position: absolute; left: 16px; top: 16px; color: var(--text-muted);">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    </span>
                    <input asp-for="Input.CurrentPassword" type="password" class="form-control" style="padding-left: 48px;" placeholder="••••••••" />
                </div>
                <span asp-validation-for="Input.CurrentPassword" class="text-danger"></span>
            </div>

            <div class="form-group" style="margin-bottom: 20px;">
                <label asp-for="Input.NewPassword" class="form-label">Mật khẩu mới</label>
                <div style="position: relative;">
                    <span style="position: absolute; left: 16px; top: 16px; color: var(--text-muted);">
                         <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.778-7.778zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3L15.5 7.5z"/></svg>
                    </span>
                    <input asp-for="Input.NewPassword" type="password" class="form-control" style="padding-left: 48px;" placeholder="Tối thiểu 6 ký tự" />
                </div>
                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
            </div>

            <div class="form-group" style="margin-bottom: 32px;">
                <label asp-for="Input.ConfirmNewPassword" class="form-label">Xác nhận mật khẩu mới</label>
                <div style="position: relative;">
                    <span style="position: absolute; left: 16px; top: 16px; color: var(--text-muted);">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </span>
                    <input asp-for="Input.ConfirmNewPassword" type="password" class="form-control" style="padding-left: 48px;" placeholder="Nhập lại mật khẩu mới" />
                </div>
                <span asp-validation-for="Input.ConfirmNewPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100" style="padding: 16px; font-size: 14px; text-transform: uppercase; letter-spacing: 0.1em;">
                Cập nhật cấu hình bảo mật
            </button>
        </form>
    </div>

    <div style="text-align: center; margin-top: 24px;">
        <a asp-page="/Account/Profile" style="font-size: 13px; color: var(--text-muted); text-decoration: none; display: inline-flex; align-items: center; gap: 8px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            Quay lại Hồ sơ cá nhân
        </a>
    </div>
</div>

<style>
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}