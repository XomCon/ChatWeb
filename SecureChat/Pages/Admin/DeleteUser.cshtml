@page
@model SecureChat.Pages.Admin.DeleteUserModel
@{
    ViewData["Title"] = "Xóa User";
}

<div class="page-box">
    <h2>Xóa tài khoản</h2>
    <div class="alert alert-warning">
        Bạn có chắc muốn xóa tài khoản này không?
    </div>

    <div class="info-grid">
        <div class="info-card">
            <span class="label">Họ tên</span>
            <span class="value">@Model.FullName</span>
        </div>
        <div class="info-card">
            <span class="label">Email</span>
            <span class="value">@Model.Email</span>
        </div>
    </div>

    <form method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-danger">Xác nhận xóa</button>
            <a asp-page="/Admin/Users" class="btn btn-outline-light">Hủy</a>
        </div>
    </form>
</div>