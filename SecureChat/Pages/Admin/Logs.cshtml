@page
@model SecureChat.Pages.Admin.LogsModel
@{
    ViewData["Title"] = "Audit Trajectory & Forensic";
}

<div class="admin-layout">
    <partial name="_AdminSidebar" />

    <div class="admin-main" style="animation: fadeInUp 0.8s ease forwards;">
        <!-- Hero Header -->
        <div class="admin-header">
            <div>
                <div class="badge-soft badge-info" style="margin-bottom: 12px;">Security Audit Loop</div>
                <h1>System Activity Logs</h1>
                <p>Truy vết và phân tích các giao thức vận hành trong hệ thống SecureChat.</p>
            </div>
            
            <div style="display: flex; gap: 12px;">
                 <a asp-page="/Admin/Index" class="btn btn-outline-light">Dashboard</a>
            </div>
        </div>

        <!-- Forensic Toolbar -->
        <div class="glass-card" style="padding: 20px; border-radius: 20px; margin-bottom: 24px; background: rgba(255,255,255,0.02);">
            <form method="get" style="display: flex; gap: 16px; align-items: center;">
                <div style="flex: 1; position: relative;">
                    <span style="position: absolute; left: 16px; top: 12px; color: var(--text-muted);">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    </span>
                    <input asp-for="Keyword" class="form-control" style="padding-left: 48px; height: 44px; border-radius: 12px;" placeholder="Truy vấn theo Action, Email, hoặc Forensic Data..." />
                </div>
                <button type="submit" class="btn btn-primary" style="height: 44px; padding: 0 24px;">Truy vết</button>
            </form>
        </div>

        <!-- Logic Audit Panel -->
        <div class="glass-card" style="padding: 0; border-radius: 24px; overflow: hidden; background: rgba(10, 12, 16, 0.4);">
            <div style="padding: 24px; border-bottom: 1px solid var(--glass-border); display: flex; justify-content: space-between; align-items: center;">
                <h3 style="font-size: 16px; margin: 0;">Audit Trajectory</h3>
                <span class="badge-soft badge-info">Real-time Forensic Feed</span>
            </div>

            <div class="table-wrap" style="overflow-x: auto;">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>Ref ID</th>
                            <th>Subject (Email)</th>
                            <th>Action Protocol</th>
                            <th>Forensic Description</th>
                            <th>Source IP</th>
                            <th style="text-align: right;">Timestamp</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.Logs)
                        {
                            <tr style="transition: all 0.3s ease;">
                                <td>
                                    <span style="font-family: 'JetBrains Mono', monospace; font-size: 11px; opacity: 0.5;">#@log.Id.ToString("D4")</span>
                                </td>
                                <td>
                                    <span style="font-weight: 700; color: #fff;">@log.UserEmail</span>
                                </td>
                                <td>
                                    <span class="badge-soft @(log.Action.Contains("Delete") || log.Action.Contains("Remove") ? "badge-danger" : "badge-emerald")" style="font-size: 10px;">
                                        @log.Action
                                    </span>
                                </td>
                                <td style="max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 13px;">
                                    @log.Description
                                </td>
                                <td>
                                    <code style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--emerald-glow);">@log.IpAddress</code>
                                </td>
                                <td style="text-align: right;">
                                    <div style="font-size: 12px; color: #fff; font-weight: 600;">@log.CreatedAt.ToString("HH:mm:ss")</div>
                                    <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase;">@log.CreatedAt.ToString("dd MMM yyyy")</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .premium-table tr:hover {
        background: rgba(16, 185, 129, 0.02) !important;
    }
</style>