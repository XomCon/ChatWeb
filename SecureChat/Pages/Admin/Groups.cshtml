@page
@model SecureChat.Pages.Admin.GroupsModel
@{
    ViewData["Title"] = "Cluster Grid Configuration";
}

<div class="admin-layout">
    <partial name="_AdminSidebar" />

    <div class="admin-main" style="animation: fadeInUp 0.8s ease forwards;">
        <!-- Hero Header -->
        <div class="admin-header">
            <div>
                <div class="badge-soft badge-warning" style="margin-bottom: 12px;">Network Hub Topology</div>
                <h1>Hub Cluster Management</h1>
                <p>Điều phối các phân vùng cộng tác và giám sát lưu lượng Cluster Nodes.</p>
            </div>
            
            <a asp-page="/Admin/Index" class="btn btn-outline-light">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><path d="m15 18-6-6 6-6"/></svg>
                Quay lại Dashboard
            </a>
        </div>

        <!-- Metric Overview -->
        <div class="admin-stats" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));">
            <div class="stat-box" style="border-left: 4px solid var(--emerald);">
                <span>Active Clusters</span>
                <h2>@Model.Groups.Count</h2>
            </div>
            <div class="stat-box" style="border-left: 4px solid #fbbf24;">
                <span>Total Payload Nodes</span>
                <h2>@Model.Groups.Sum(g => g.MemberCount)</h2>
            </div>
        </div>

        <!-- Main Cluster Panel -->
        <div class="glass-card" style="padding: 0; border-radius: 24px; overflow: hidden; background: rgba(10, 12, 16, 0.4);">
            <div style="padding: 24px; border-bottom: 1px solid var(--glass-border); display: flex; justify-content: space-between; align-items: center;">
                <h3 style="font-size: 16px; margin: 0;">Cluster Grid Map</h3>
                <span class="badge-soft badge-warning">Network Transparency Active</span>
            </div>

            <div class="table-wrap" style="overflow-x: auto;">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>Ref Cluster ID</th>
                            <th>Alias (Name)</th>
                            <th>Node Capacity</th>
                            <th>Payload (Messages)</th>
                            <th>Inception Date</th>
                            <th style="text-align: right;">Giao thức truy cập</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var g in Model.Groups)
                        {
                            <tr style="transition: all 0.3s ease;">
                                <td>
                                    <span style="font-family: 'JetBrains Mono', monospace; font-size: 11px; opacity: 0.5;">#HUB-@g.Id.ToString("D3")</span>
                                </td>
                                <td>
                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        <div style="width: 32px; height: 32px; border-radius: 8px; background: linear-gradient(135deg, #fbbf24, #d97706); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 12px; color: #fff;">
                                            @(g.Name?.Substring(0, 1).ToUpper() ?? "H")
                                        </div>
                                        <span style="font-weight: 700; color: #fff;">@g.Name</span>
                                    </div>
                                </td>
                                <td>
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <span style="color: #fff; font-weight: 700;">@g.MemberCount</span>
                                        <span style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Nodes</span>
                                    </div>
                                </td>
                                <td>
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <span style="color: #38bdf8; font-weight: 700;">@g.MessageCount</span>
                                        <span style="font-size: 11px; color: var(--text-muted); text-transform: uppercase;">Packets</span>
                                    </div>
                                </td>
                                <td>
                                    <div style="font-size: 12px; color: #fff;">@g.CreatedAt.ToString("HH:mm")</div>
                                    <div style="font-size: 11px; color: var(--text-muted);">@g.CreatedAt.ToString("dd/MM/yyyy")</div>
                                </td>
                                <td style="text-align: right;">
                                    <a asp-page="/Groups/Chat" asp-route-conversationId="@g.Id" class="btn btn-outline-light" style="padding: 8px 16px; font-size: 11px; border-radius: 8px; background: rgba(56, 189, 248, 0.05); border-color: rgba(56, 189, 248, 0.1); color: #38bdf8;">
                                        Audit Cluster
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>