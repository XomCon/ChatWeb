@page
@model SecureChat.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Identity Access Management";
}

<div class="admin-layout">
    <partial name="_AdminSidebar" />

    <div class="admin-main" style="animation: fadeInUp 0.8s ease forwards;">
        <!-- Hero Header -->
        <div class="admin-header">
            <div>
                <div class="badge-soft badge-info" style="margin-bottom: 12px;">Identity Matrix</div>
                <h1>Quản lý Identity Nodes</h1>
                <p>Giám sát, phân quyền và điều phối các đơn vị tham gia hệ thống.</p>
            </div>
            
            <a asp-page="/Admin/Index" class="btn btn-outline-light">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><path d="m15 18-6-6 6-6"/></svg>
                Quay lại Dashboard
            </a>
        </div>

        <!-- Filter Toolbar -->
        <div class="glass-card" style="padding: 20px; border-radius: 20px; margin-bottom: 24px; background: rgba(255,255,255,0.02);">
            <form method="get" style="display: flex; gap: 16px; align-items: center; flex-wrap: wrap;">
                <div style="flex: 1; position: relative; min-width: 280px;">
                    <span style="position: absolute; left: 16px; top: 12px; color: var(--text-muted);">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    </span>
                    <input asp-for="Keyword" class="form-control" style="padding-left: 48px; height: 44px; border-radius: 12px;" placeholder="Tìm Node theo tên, email, SĐT..." />
                </div>
                
                <select asp-for="RoleFilter" class="form-select" style="max-width:200px; height: 44px; border-radius: 12px; background: rgba(0,0,0,0.2); border-color: rgba(255,255,255,0.05); color: #fff;">
                    <option value="">Tất cả vai trò</option>
                    <option value="Admin">Điều phối (Admin)</option>
                    <option value="User">Thành viên (User)</option>
                </select>
                
                <button type="submit" class="btn btn-primary" style="height: 44px; padding: 0 24px;">Lọc Nodes</button>
            </form>
        </div>

        <!-- Main Table Panel -->
        <div class="glass-card" style="padding: 0; border-radius: 24px; overflow: hidden; background: rgba(10, 12, 16, 0.4);">
            <div style="padding: 24px; border-bottom: 1px solid var(--glass-border); display: flex; justify-content: space-between; align-items: center;">
                <h3 style="font-size: 16px; margin: 0;">Danh sách Node hiện hữu</h3>
                <span class="badge-soft badge-emerald">@Model.Users.Count Tổng số Node</span>
            </div>

            <div class="table-wrap" style="overflow-x: auto;">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>Định danh Node</th>
                            <th>Thông tin liên lạc</th>
                            <th>Vai trò</th>
                            <th>Trạng thái</th>
                            <th>Hoạt động</th>
                            <th>Lịch sử tạo</th>
                            <th style="text-align: right;">Giao thức điều khiển</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model.Users)
                        {
                            <tr>
                                <td>
                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        <div style="width: 32px; height: 32px; border-radius: 8px; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 12px;">
                                            @(u.FullName?.Substring(0, 1).ToUpper() ?? "U")
                                        </div>
                                        <span style="font-weight: 700; color: #fff;">@u.FullName</span>
                                    </div>
                                </td>
                                <td>
                                    <div style="font-size: 13px;">@u.Email</div>
                                    <div style="font-size: 11px; color: var(--text-muted);">@u.PhoneNumber</div>
                                </td>
                                <td>
                                    @if (u.Role == "Admin")
                                    {
                                        <span class="badge-soft badge-warning">Coordinator</span>
                                    }
                                    else
                                    {
                                        <span class="badge-soft badge-info">Operative</span>
                                    }
                                </td>
                                <td>
                                    @if (u.IsActive)
                                    {
                                        <span class="badge-soft badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-soft badge-danger">Locked</span>
                                    }
                                </td>
                                <td>
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <span class="status-dot @(u.IsOnline ? "status-dot--online" : "status-dot--offline")"></span>
                                        <span style="font-size: 11px; color: @(u.IsOnline ? "var(--emerald-glow)" : "var(--text-muted)");">
                                            @(u.IsOnline ? "Connected" : "Idle")
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <div style="font-size: 12px;">@u.CreatedAt.ToString("HH:mm")</div>
                                    <div style="font-size: 11px; color: var(--text-muted);">@u.CreatedAt.ToString("dd/MM/yyyy")</div>
                                </td>
                                <td style="text-align: right;">
                                    <div style="display: flex; gap: 8px; justify-content: flex-end;">
                                        <a asp-page="/Admin/EditUser" asp-route-id="@u.Id" class="btn btn-outline-light" style="padding: 6px 12px; font-size: 11px; border-radius: 8px;">Hiệu chỉnh</a>
                                        <a asp-page="/Admin/DeleteUser" asp-route-id="@u.Id" class="btn btn-danger" style="padding: 6px 12px; font-size: 11px; border-radius: 8px; background: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.2); color: #ef4444;">Loại bỏ</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>