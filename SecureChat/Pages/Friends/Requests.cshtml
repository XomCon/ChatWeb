@page
@model SecureChat.Pages.Friends.RequestsModel
@{
    ViewData["Title"] = "Lời mời kết bạn";
}

<div class="page-box-wide">
    <h2>Lời mời kết bạn</h2>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div class="mt-4">
        <h3>Lời mời nhận được</h3>

        @if (Model.IncomingRequests.Any())
        {
            <div class="table-wrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Người gửi</th>
                            <th>Email</th>
                            <th>Ngày gửi</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.IncomingRequests)
                        {
                            <tr>
                                <td>@item.FullName</td>
                                <td>@item.Email</td>
                                <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <form method="post" asp-page-handler="Accept" style="display:inline;">
                                        <input type="hidden" name="requestId" value="@item.Id" />
                                        <button type="submit" class="btn btn-success">Chấp nhận</button>
                                    </form>

                                    <form method="post" asp-page-handler="Reject" style="display:inline; margin-left:8px;">
                                        <input type="hidden" name="requestId" value="@item.Id" />
                                        <button type="submit" class="btn btn-danger">Từ chối</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">Bạn chưa có lời mời kết bạn nào.</div>
        }
    </div>

    <div class="mt-5">
        <h3>Lời mời đã gửi</h3>

        @if (Model.SentRequests.Any())
        {
            <div class="table-wrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Người nhận</th>
                            <th>Email</th>
                            <th>Ngày gửi</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.SentRequests)
                        {
                            <tr>
                                <td>@item.FullName</td>
                                <td>@item.Email</td>
                                <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <form method="post" asp-page-handler="Cancel" style="display:inline;">
                                        <input type="hidden" name="requestId" value="@item.Id" />
                                        <button type="submit" class="btn btn-danger">Hủy lời mời</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">Bạn chưa gửi lời mời kết bạn nào.</div>
        }
    </div>

    <div class="mt-4">
        <a asp-page="/Friends/FindUsers" class="btn btn-outline-light">Tìm người dùng</a>
        <a asp-page="/Friends/Index" class="btn btn-outline-light">Danh sách bạn bè</a>
    </div>
</div>