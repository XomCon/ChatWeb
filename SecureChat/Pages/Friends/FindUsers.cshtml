@page
@model SecureChat.Pages.Friends.FindUsersModel
@{
    ViewData["Title"] = "Phát hiện Node";
}

<div class="page-box-wide" style="animation: fadeInUp 0.8s ease forwards;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
        <div>
            <div class="badge-soft" style="background: rgba(168, 85, 247, 0.1); color: #a855f7; border: 1px solid rgba(168, 85, 247, 0.2); margin-bottom: 12px;">Discovery Mode Active</div>
            <h2 style="font-size: 28px; margin: 0;">Tìm kiếm người dùng</h2>
            <p style="color: var(--text-muted); font-size: 14px; margin-top: 4px;">Quét mạng lưới để tìm kiếm và khởi tạo liên kết với các Node mới.</p>
        </div>
        <div style="display: flex; gap: 12px;">
            <a asp-page="/Friends/Index" class="btn btn-outline-light">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Mạng lưới của tôi
            </a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success" style="border-radius: 12px; margin-bottom: 24px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><polyline points="20 6 9 17 4 12"/></svg>
            @Model.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" style="border-radius: 12px; margin-bottom: 24px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @Model.ErrorMessage
        </div>
    }

    <div class="glass-card" style="padding: 32px; margin-bottom: 40px; background: rgba(255,255,255,0.02);">
        <form method="get">
            <div style="display: flex; gap: 16px;">
                <div style="flex: 1; position: relative;">
                    <span style="position: absolute; left: 16px; top: 16px; color: var(--text-muted);">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    </span>
                    <input asp-for="Keyword" class="form-control" style="padding-left: 52px; height: 52px;" placeholder="Tìm theo tên, email hoặc số điện thoại..." />
                </div>
                <button type="submit" class="btn btn-primary" style="padding: 0 32px;">Tiến hành quét</button>
            </div>
        </form>
    </div>

    @if (Model.Users.Any())
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px;">
            @foreach (var user in Model.Users)
            {
                <div class="glass-card" style="padding: 24px; transition: var(--transition-bounce);">
                    <div style="display: flex; gap: 16px; align-items: center; margin-bottom: 20px;">
                        <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(255,255,255,0.03); display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 800; color: #fff;">
                            @(string.IsNullOrWhiteSpace(user.FullName) ? "U" : user.FullName.Substring(0, 1).ToUpper())
                        </div>
                        <div style="flex: 1; min-width: 0;">
                            <h4 style="font-size: 15px; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@user.FullName</h4>
                            <p style="color: var(--text-muted); font-size: 12px; margin: 2px 0 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@user.Email</p>
                        </div>
                        @if (user.IsOnline)
                        {
                            <div style="width: 10px; height: 10px; border-radius: 50%; background: var(--emerald); box-shadow: 0 0 8px var(--emerald);" title="Online"></div>
                        }
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px;">
                         <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-size: 11px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">Identity</span>
                            <span class="badge-soft" style="font-size: 10px; background: rgba(56, 189, 248, 0.1); color: #38bdf8;">Verified Node</span>
                        </div>
                    </div>

                    <div style="margin-top: auto;">
                        @if (user.IsFriend)
                        {
                            <div class="btn btn-outline-light w-100" style="opacity: 0.6; cursor: default;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><path d="M20 6 9 17 4 12"/></svg>
                                Đã kết nối
                            </div>
                        }
                        else if (user.IsPendingSent)
                        {
                            <div class="btn btn-outline-light w-100" style="border-color: rgba(251, 191, 36, 0.3); color: #fbbf24; cursor: default;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                Tín hiệu đang chờ...
                            </div>
                        }
                        else if (user.IsPendingReceived)
                        {
                            <a asp-page="/Friends/Requests" class="btn btn-primary w-100">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><path d="M22 17a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9.5C2 7 4 5 6.5 5H18c2.2 0 4 1.8 4 4v8Z"/><path d="m22 9-10 7L2 9"/></svg>
                                Phản hồi yêu cầu
                            </a>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="SendRequest">
                                <input type="hidden" name="receiverId" value="@user.Id" />
                                <input type="hidden" name="Keyword" value="@Model.Keyword" />
                                <button type="submit" class="btn btn-primary w-100">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                                    Gửi yêu cầu kết nối
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else if (!string.IsNullOrEmpty(Model.Keyword))
    {
        <div class="glass-card" style="padding: 60px; text-align: center;">
            <div style="width: 64px; height: 64px; border-radius: 50%; background: rgba(239, 68, 68, 0.05); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; color: #ef4444;">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><line x1="8" y1="8" x2="14" y2="14"/><line x1="14" y1="8" x2="8" y2="14"/></svg>
            </div>
            <h3 style="font-size: 20px; color: #fff;">Không tìm thấy Node phù hợp</h3>
            <p style="color: var(--text-muted); max-width: 400px; margin: 8px auto 0;">Hãy thử lại với từ khóa khác như email hoặc số điện thoại chính xác.</p>
        </div>
    }
    else
    {
       <div class="glass-card" style="padding: 60px; text-align: center; border-style: dashed; background: transparent;">
            <div style="width: 64px; height: 64px; border-radius: 50%; background: rgba(255,255,255,0.03); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; color: var(--text-muted);">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
            <h3 style="font-size: 20px; color: #fff;">Sẵn sàng quét mạng lưới</h3>
            <p style="color: var(--text-muted); max-width: 400px; margin: 8px auto 0;">Nhập thông tin định danh vào thanh tìm kiếm phía trên để bắt đầu khám phá các Node liên kết.</p>
        </div>
    }
</div>

<style>
    .glass-card:hover {
        transform: translateY(-5px);
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(168, 85, 247, 0.3);
    }
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>