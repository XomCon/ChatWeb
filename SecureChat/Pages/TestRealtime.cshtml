@page
@model SecureChat.Pages.TestRealtimeModel
@{
    ViewData["Title"] = "SignalR Diagnostic Portal";
}

<div class="page-box-wide" style="animation: fadeInUp 0.8s ease forwards;">
    <div class="admin-header">
        <div>
            <div class="badge-soft badge-info" style="margin-bottom: 12px;">Real-time Socket Audit</div>
            <h1>SignalR Diagnostic Portal</h1>
            <p>Kiểm tra tính toàn vẹn của kết nối Real-time Hub và giao thức truyền tin.</p>
        </div>
        <div class="badge-soft badge-emerald">
            <div id="connStatusDot" class="status-dot status-dot--offline" style="margin-right:8px"></div>
            <span id="connStatusText">Hub Disconnected</span>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 350px 1fr; gap: 24px;">
        <!-- Control Panel -->
        <div class="glass-card" style="padding: 32px; border-radius: 30px;">
            <h4 style="font-size: 14px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 24px;">Transmission Config</h4>
            
            <div class="form-group">
                <label class="form-label">Source Alias (Tên)</label>
                <input type="text" id="senderInput" class="form-control" placeholder="Nhập định danh..." />
            </div>

            <div class="form-group">
                <label class="form-label">Target Hub Cluster (Phòng)</label>
                <input type="text" id="roomInput" class="form-control" value="room1" />
            </div>

            <button type="button" class="btn btn-outline-light" id="joinBtn" style="width: 100%; margin-bottom: 32px;">
                Initialize Join Protocol
            </button>

            <h4 style="font-size: 14px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 24px;">Data Payload</h4>
            
            <div class="form-group">
                <label class="form-label">Message Packet</label>
                <input type="text" id="messageInput" class="form-control" placeholder="Nhập payload..." />
            </div>

            <button type="button" class="btn btn-primary" id="sendBtn" style="width: 100%;">
                Broadcast Packet
            </button>
        </div>

        <!-- Monitor Panel -->
        <div class="glass-card" style="padding: 0; border-radius: 30px; display: flex; flex-direction: column;">
            <div style="padding: 24px; border-bottom: 1px solid var(--glass-border); display: flex; justify-content: space-between; align-items: center;">
                <h3 style="font-size: 16px; margin: 0;">Packet Monitor</h3>
                <span class="badge-soft badge-info" style="font-size: 10px;">Forensic Feed</span>
            </div>
            
            <div id="messages" style="flex: 1; padding: 24px; min-height: 400px; font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--text-secondary); overflow-y: auto; background: rgba(0,0,0,0.2);">
                <!-- Logs will appear here -->
                <div style="color: var(--text-muted);">[SYSTEM] Waiting for SignalR handshake...</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        const senderInput = document.getElementById("senderInput");
        const roomInput = document.getElementById("roomInput");
        const messageInput = document.getElementById("messageInput");
        const joinBtn = document.getElementById("joinBtn");
        const sendBtn = document.getElementById("sendBtn");
        const messagesDiv = document.getElementById("messages");
        const connStatusDot = document.getElementById("connStatusDot");
        const connStatusText = document.getElementById("connStatusText");

        function log(msg, type = 'system') {
            const div = document.createElement("div");
            div.style.marginBottom = "8px";
            div.style.padding = "8px 12px";
            div.style.borderRadius = "8px";
            
            if (type === 'receive') {
                div.style.background = "rgba(16, 185, 129, 0.05)";
                div.style.borderLeft = "2px solid var(--emerald)";
                div.innerHTML = `<span style="color:var(--emerald-glow)">[RECEIVE]</span> ${msg}`;
            } else if (type === 'error') {
                div.style.background = "rgba(239, 68, 68, 0.05)";
                div.style.borderLeft = "2px solid #ef4444";
                div.innerHTML = `<span style="color:#fca5a5">[ERROR]</span> ${msg}`;
            } else {
                div.style.color = "var(--text-muted)";
                div.innerHTML = `<span>[SYSTEM]</span> ${msg}`;
            }
            
            messagesDiv.appendChild(div);
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

        connection.on("ReceiveMessage", function (sender, message) {
            log(`<strong>${escapeHtml(sender)}:</strong> ${escapeHtml(message)}`, 'receive');
        });

        connection.start()
            .then(() => {
                log("SignalR connection established safely.");
                connStatusDot.className = "status-dot status-dot--online";
                connStatusText.innerText = "Hub Connected & Secure";
            })
            .catch(err => {
                log("Connection sequence failed: " + err, 'error');
                connStatusDot.className = "status-dot";
                connStatusDot.style.background = "#ef4444";
                connStatusText.innerText = "Protocol Fault";
            });

        joinBtn.addEventListener("click", async function () {
            const room = roomInput.value.trim();
            if (!room) return;

            try {
                await connection.invoke("JoinRoom", room);
                log(`Successfully joined Hub Cluster: ${room}`);
            } catch (err) {
                log("Join protocol failed: " + err, 'error');
            }
        });

        async function sendMessage() {
            const sender = senderInput.value.trim();
            const room = roomInput.value.trim();
            const msg = messageInput.value.trim();

            if (!sender || !room || !msg) return;

            try {
                await connection.invoke("SendMessageToRoom", room, sender, msg);
                log(`Broadcast successful to Cluster: ${room}`);
                messageInput.value = "";
            } catch (err) {
                log("Broadcast failed: " + err, 'error');
            }
        }

        sendBtn.addEventListener("click", sendMessage);

        messageInput.addEventListener("keydown", function (e) {
            if (e.key === "Enter") {
                e.preventDefault();
                sendMessage();
            }
        });

        function escapeHtml(text) {
            const div = document.createElement("div");
            div.innerText = text;
            return div.innerHTML;
        }
    </script>
}

<style>
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>