@page
@model ErrorModel
@{
    ViewData["Title"] = "System Fault Encountered";
}

<div style="min-height: 80vh; display: flex; align-items: center; justify-content: center; animation: fadeIn 1s ease;">
    <div class="glass-card" style="max-width: 600px; padding: 60px; border-radius: 40px; text-align: center; border-color: rgba(239, 68, 68, 0.2);">
        <div style="width: 100px; height: 100px; border-radius: 30px; background: rgba(239, 68, 68, 0.1); color: #ef4444; display: flex; align-items: center; justify-content: center; margin: 0 auto 32px; box-shadow: 0 0 40px rgba(239, 68, 68, 0.15);">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>

        <h1 style="font-size: 32px; color: #fff; margin-bottom: 12px;">Protocol Interruption</h1>
        <p style="color: var(--text-secondary); font-size: 16px; margin-bottom: 40px;">Một ngoại lệ hệ thống đã làm gián đoạn giao thức xử lý yêu cầu của bạn.</p>

        @if (Model.ShowRequestId)
        {
            <div style="background: rgba(0,0,0,0.3); padding: 20px; border-radius: 16px; margin-bottom: 40px; border: 1px solid var(--glass-border);">
                <div style="font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 8px;">Incident Request ID</div>
                <code style="font-family: 'JetBrains Mono', monospace; color: #fca5a5; font-size: 14px;">@Model.RequestId</code>
            </div>
        }

        <div style="display: flex; gap: 16px; justify-content: center;">
            <a asp-page="/Index" class="btn btn-primary" style="padding: 14px 32px;">Initialize Recovery</a>
            <a href="javascript:history.back()" class="btn btn-outline-light" style="padding: 14px 32px;">Back to Node</a>
        </div>
    </div>
</div>

<style>
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
</style>
