@page
@model SecureChat.Pages.Groups.IndexModel
@{
    ViewData["Title"] = "Secure Node Clusters";
}

<div class="page-box-wide" style="animation: fadeInUp 0.8s ease forwards;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
        <div>
            <h2 style="font-size: 28px; margin: 0;">Quản lý Nhóm chat</h2>
            <p style="color: var(--text-muted); font-size: 14px; margin-top: 4px;">Tập hợp các Node liên kết trong môi trường cộng tác bảo mật.</p>
        </div>
        <a asp-page="/Groups/Create" class="btn btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            Khởi tạo Cluster mới
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success" style="border-radius: 12px; margin-bottom: 24px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><polyline points="20 6 9 17 4 12"/></svg>
            @Model.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" style="border-radius: 12px; margin-bottom: 24px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @Model.ErrorMessage
        </div>
    }

    @if (Model.Groups.Any())
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px;">
            @foreach (var group in Model.Groups)
            {
                <div class="glass-card" style="padding: 24px; transition: var(--transition-bounce); position: relative; overflow: hidden;">
                    <div style="display: flex; gap: 16px; align-items: center; margin-bottom: 20px;">
                        <div style="width: 52px; height: 52px; border-radius: 14px; background: linear-gradient(135deg, rgba(251, 191, 36, 0.1), rgba(251, 191, 36, 0.05)); border: 1px solid rgba(251, 191, 36, 0.2); display: flex; align-items: center; justify-content: center; font-size: 20px; color: #fbbf24;">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
                        </div>
                        <div style="flex: 1; min-width: 0;">
                            <h4 style="font-size: 16px; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@group.GroupName</h4>
                            <p style="color: var(--text-muted); font-size: 11px; margin: 2px 0 0; text-transform: uppercase; letter-spacing: 0.05em;">SECURE CLUSTER</p>
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; padding: 12px; background: rgba(255,255,255,0.02); border-radius: 12px; border: 1px solid rgba(255,255,255,0.03);">
                        <div>
                            <span style="display: block; font-size: 10px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">Members</span>
                            <span style="font-size: 14px; color: #fff; font-weight: 800;">@group.MemberCount Nodes</span>
                        </div>
                        <div style="text-align: right;">
                            <span style="display: block; font-size: 10px; color: var(--text-muted); font-weight: 700; text-transform: uppercase;">Created</span>
                            <span style="font-size: 12px; color: var(--text-secondary);">@group.CreatedAt.ToString("dd/MM/yyyy")</span>
                        </div>
                    </div>

                    <a asp-page="/Groups/Chat" asp-route-conversationId="@group.ConversationId" class="btn btn-primary w-100" style="padding: 12px; font-size: 13px; background: linear-gradient(135deg, #fbbf24, #d97706); box-shadow: 0 8px 15px rgba(251, 191, 36, 0.2);">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        Truy cập Cluster
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="glass-card" style="padding: 60px; text-align: center;">
            <div style="width: 64px; height: 64px; border-radius: 50%; background: rgba(255,255,255,0.03); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; color: var(--text-muted);">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
            </div>
            <h3 style="font-size: 20px; color: #fff;">Chưa tham gia Cluster nào</h3>
            <p style="color: var(--text-muted); max-width: 400px; margin: 8px auto 24px;">Bạn có thể khởi tạo một nhóm chat mới hoặc chờ lời mời từ các Node điều phối khác.</p>
            <a asp-page="/Groups/Create" class="btn btn-primary">Khởi tạo Cluster mới</a>
        </div>
    }
</div>

<style>
    .glass-card:hover {
        transform: translateY(-5px);
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(251, 191, 36, 0.3);
    }
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>