@page
@model SecureChat.Pages.Groups.IndexModel
@{
    ViewData["Title"] = "Nhóm chat";
}

<div class="page-box-wide">
    <div class="d-flex justify-between align-center mb-4">
        <div>
            <h2>Nhóm chat</h2>
            <p class="text-muted">Danh sách các nhóm bạn đang tham gia.</p>
        </div>
        <div>
            <a asp-page="/Groups/Create" class="btn btn-primary">Tạo nhóm mới</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (Model.Groups.Any())
    {
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Tên nhóm</th>
                        <th>Số thành viên</th>
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var group in Model.Groups)
                    {
                        <tr>
                            <td>@group.GroupName</td>
                            <td>@group.MemberCount</td>
                            <td>@group.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <a asp-page="/Groups/Chat" asp-route-conversationId="@group.ConversationId" class="btn btn-secondary">
                                    Vào nhóm
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">Bạn chưa tham gia nhóm chat nào.</div>
    }
</div>