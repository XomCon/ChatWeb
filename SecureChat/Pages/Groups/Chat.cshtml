@page
@model SecureChat.Pages.Groups.ChatModel
@{
    ViewData["Title"] = $"Cluster: {Model.GroupName}";
}

<div class="chat-container-layout" style="height: calc(100vh - 160px); display: grid; grid-template-columns: 1fr 340px; gap: 24px; animation: fadeInUp 0.8s ease forwards;">
    
    <!-- ── Left: Main Chat Area ── -->
    <div style="display: flex; flex-direction: column; min-width: 0;">
        <!-- Chat Header -->
        <div class="glass-card" style="padding: 16px 24px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; border-radius: 20px;">
            <div style="display: flex; align-items: center; gap: 16px;">
                <div style="width: 44px; height: 44px; border-radius: 12px; background: linear-gradient(135deg, #fbbf24, #d97706); display: flex; align-items: center; justify-content: center; font-weight: 800; color: #fff;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
                </div>
                <div>
                    <h3 style="font-size: 16px; margin: 0;">@Model.GroupName</h3>
                    <div style="font-size: 11px; color: var(--text-muted); display: flex; align-items: center; gap: 6px; margin-top: 2px;">
                        <span class="status-dot status-dot--online"></span>
                        <span style="color: var(--emerald-glow);">Secure Cluster Link Active</span>
                    </div>
                </div>
            </div>
            
            @if (Model.IsGroupAdmin)
            {
                <div class="badge-soft badge-warning">Admin Access Active</div>
            }
        </div>

        <!-- Messages Area -->
        <div class="glass-card" style="flex: 1; margin-bottom: 20px; display: flex; flex-direction: column; overflow: hidden; border-radius: 24px; background: rgba(10, 12, 16, 0.4);">
            <div id="chatMessages" style="flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 20px; scroll-behavior: smooth;">
                @if (Model.Messages.Any())
                {
                    @foreach (var message in Model.Messages)
                    {
                        <div class="message-row @(message.IsMine ? "mine" : "other")" style="display: flex; flex-direction: column; align-items: @(message.IsMine ? "flex-end" : "flex-start");">
                            @if (!message.IsMine)
                            {
                                <span style="font-size: 11px; font-weight: 800; color: var(--emerald-glow); margin-bottom: 4px; margin-left: 12px;">@message.SenderName</span>
                            }
                            <div class="message-bubble" style="max-width: 75%; padding: 12px 18px; border-radius: 18px; font-size: 14px; line-height: 1.5; position: relative; @(message.IsMine ? "background: linear-gradient(135deg, var(--emerald), var(--emerald-dark)); color: #fff; border-bottom-right-radius: 4px;" : "background: rgba(255, 255, 255, 0.05); border: 1px solid var(--glass-border); color: #fff; border-bottom-left-radius: 4px;")">
                                @message.Content
                            </div>
                            <div style="margin-top: 6px; padding: 0 4px;">
                                <span style="font-size: 10px; color: var(--text-muted);">@message.SentAt.ToString("HH:mm · dd/MM/yyyy")</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div id="noMessagesPlaceholder" style="margin: auto; text-align: center; opacity: 0.5;">
                        <div style="width: 48px; height: 48px; border-radius: 50%; background: rgba(255,255,255,0.03); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        </div>
                        <p style="font-size: 13px;">Không có dữ liệu truyền tin trong cluster này.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Input Area -->
        <div class="glass-card" style="padding: 12px; border-radius: 20px; background: rgba(255, 255, 255, 0.03);">
            <form id="chatForm" style="display: flex; gap: 12px; align-items: center;">
                <div style="flex: 1; position: relative;">
                     <input type="text" id="messageInput" class="form-control" style="height: 48px; border-radius: 12px; background: rgba(0,0,0,0.2); border-color: rgba(255,255,255,0.05);" placeholder="Gửi bản tin tới Cluster..." autocomplete="off" />
                </div>
                <button type="submit" class="btn btn-primary" style="width: 48px; height: 48px; border-radius: 12px; padding: 0; background: linear-gradient(135deg, #fbbf24, #d97706); border: none;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polyline points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </button>
            </form>
        </div>
    </div>

    <!-- ── Right: Sidebar Cluster Info ── -->
    <div style="display: flex; flex-direction: column; gap: 24px; overflow-y: auto;">
        <!-- Cluster Control -->
        <div class="glass-card" style="padding: 24px; border-radius: 24px;">
            <h4 style="font-size: 14px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 20px;">Cluster Control</h4>
            
            <div style="display: flex; flex-direction: column; gap: 12px;">
                <form method="post" asp-page-handler="LeaveGroup">
                    <input type="hidden" asp-for="ConversationId" />
                    <button type="submit" class="btn btn-danger w-100" style="justify-content: center; font-size: 13px;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Rời khỏi Cluster
                    </button>
                </form>

                @if (Model.IsGroupAdmin)
                {
                    <form method="post" asp-page-handler="DeleteGroup" onsubmit="return confirm('Xác nhận hủy diệt Cluster này?');">
                        <input type="hidden" asp-for="ConversationId" />
                        <button type="submit" class="btn btn-danger w-100" style="justify-content: center; font-size: 13px; background: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.2); color: #ef4444;">
                             Hủy diệt Cluster
                        </button>
                    </form>
                }
                
                <a asp-page="/Groups/Index" class="btn btn-outline-light w-100" style="justify-content: center; font-size: 13px;">Quay lại danh sách</a>
            </div>
        </div>

        <!-- Member Nodes -->
        <div class="glass-card" style="padding: 24px; border-radius: 24px; flex: 1; display: flex; flex-direction: column;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h4 style="font-size: 14px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin: 0;">Member Nodes</h4>
                <span class="badge-soft badge-emerald" style="font-size: 10px;">@Model.Members.Count Active</span>
            </div>

            <div style="display: flex; flex-direction: column; gap: 12px; flex: 1;">
                @foreach (var member in Model.Members)
                {
                    <div class="member-node-item" style="padding: 10px; border-radius: 12px; background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.03); display: flex; align-items: center; gap: 12px;">
                        <div style="width: 32px; height: 32px; border-radius: 8px; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 12px; color: #fff;">
                            @(string.IsNullOrWhiteSpace(member.FullName) ? "U" : member.FullName.Substring(0, 1).ToUpper())
                        </div>
                        <div style="flex: 1; min-width: 0;">
                            <div style="font-size: 13px; font-weight: 700; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                @member.FullName
                                @if (member.IsCurrentUser)
                                {
                                    <span style="color: var(--emerald-glow); margin-left: 4px;">(Bạn)</span>
                                }
                            </div>
                            <div style="font-size: 10px; color: var(--text-muted);">
                                @(member.Role == "GroupAdmin" ? "Coordinator" : "Operative")
                            </div>
                        </div>
                        @if (Model.IsGroupAdmin && !member.IsCurrentUser)
                        {
                            <div class="admin-actions-mini" style="display: flex; gap: 4px;">
                                <form method="post" asp-page-handler="RemoveMember">
                                    <input type="hidden" asp-for="ConversationId" />
                                    <input type="hidden" name="memberUserId" value="@member.UserId" />
                                    <button type="submit" style="background:none; border:none; padding: 4px; color: #ef4444; opacity: 0.5; cursor: pointer;" title="Loại bỏ Node">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (Model.IsGroupAdmin && Model.AvailableFriends.Any())
            {
                <div style="margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--glass-border);">
                     <button type="button" class="btn btn-primary w-100" style="font-size: 12px; background: rgba(16, 185, 129, 0.1); color: var(--emerald-glow); border: 1px solid rgba(16, 185, 129, 0.2);" onclick="document.getElementById('addMemberSection').style.display='block'">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                        Mời thêm Node
                     </button>
                </div>
            }
        </div>
    </div>
</div>

<!-- ── Add Member Floating Section ── -->
<div id="addMemberSection" style="display:none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(8px); z-index: 1000; align-items: center; justify-content: center;">
     <div class="glass-card" style="width: 100%; max-width: 500px; padding: 32px;">
         <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
             <h3 style="margin: 0; font-size: 20px;">Mời Node thành viên</h3>
             <button onclick="document.getElementById('addMemberSection').style.display='none'" style="background: none; border: none; color: #fff; cursor: pointer;">
                 <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
             </button>
         </div>
         
         <form method="post" asp-page-handler="AddMembers">
             <input type="hidden" asp-for="ConversationId" />
             <div style="max-height: 300px; overflow-y: auto; display: flex; flex-direction: column; gap: 8px; margin-bottom: 24px;">
                 @foreach (var friend in Model.AvailableFriends)
                 {
                     <label style="display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 12px; background: rgba(255,255,255,0.03); cursor: pointer;">
                         <input type="checkbox" name="SelectedFriendIds" value="@friend.UserId" />
                         <span style="font-size: 14px;">@friend.FullName (@friend.Email)</span>
                     </label>
                 }
             </div>
             <button type="submit" class="btn btn-primary w-100">Xác nhận mời</button>
         </form>
     </div>
</div>

<style>
    #chatMessages::-webkit-scrollbar { width: 6px; }
    #chatMessages::-webkit-scrollbar-track { background: transparent; }
    #chatMessages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.05); border-radius: 10px; }
    
    .member-node-item:hover {
        background: rgba(255, 255, 255, 0.05) !important;
        border-color: rgba(16, 185, 129, 0.2) !important;
    }
    
    @@media (max-width: 1000px) {
        .chat-container-layout { grid-template-columns: 1fr; }
        div[style*="grid-template-columns: 1fr 340px"] > div:last-child { display: none; }
    }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const conversationId = "@Model.ConversationId";
        const currentUserId = "@Model.CurrentUserId";
        const currentUserName = "@Model.CurrentUserName";
        const roomName = "Conversation_" + conversationId;
        const chatMessages = document.getElementById("chatMessages");
        const chatForm = document.getElementById("chatForm");
        const messageInput = document.getElementById("messageInput");

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveMessage", function (senderId, message, sentAt, messageId) {
            appendMessage({ senderId, senderName: (senderId === currentUserId ? currentUserName : "Thành viên"), content: message, sentAt });
            const placeholder = document.getElementById("noMessagesPlaceholder");
            if (placeholder) placeholder.remove();
            chatMessages.scrollTop = chatMessages.scrollHeight;
            
            if (document.hasFocus() && senderId !== currentUserId) {
                connection.invoke("MarkAsSeen", parseInt(conversationId), currentUserId);
            }
        });

        connection.start()
            .then(() => {
                connection.invoke("JoinRoom", roomName);
                connection.invoke("MarkAsSeen", parseInt(conversationId), currentUserId);
            })
            .catch(err => console.error(err.toString()));

        chatForm.addEventListener("submit", (e) => {
            e.preventDefault();
            sendMessage();
        });

        async function sendMessage() {
            const text = messageInput.value.trim();
            if (!text) return;
            try {
                await connection.invoke("SendMessageToRoom", roomName, currentUserId, text, parseInt(conversationId));
                messageInput.value = "";
            } catch (err) {
                console.error(err.toString());
            }
        }

        function appendMessage(msg) {
            const isMine = msg.senderId === currentUserId;
            const row = document.createElement("div");
            row.className = `message-row ${isMine ? "mine" : "other"}`;
            row.style.display = "flex";
            row.style.flexDirection = "column";
            row.style.alignItems = isMine ? "flex-end" : "flex-start";

            row.innerHTML = `
                ${!isMine ? `<span style="font-size: 11px; font-weight: 800; color: var(--emerald-glow); margin-bottom: 4px; margin-left: 12px;">${escapeHtml(msg.senderName)}</span>` : ""}
                <div class="message-bubble" style="max-width: 75%; padding: 12px 18px; border-radius: 18px; font-size: 14px; line-height: 1.5; position: relative; ${isMine ? "background: linear-gradient(135deg, var(--emerald), var(--emerald-dark)); color: #fff; border-bottom-right-radius: 4px;" : "background: rgba(255, 255, 255, 0.05); border: 1px solid var(--glass-border); color: #fff; border-bottom-left-radius: 4px;"}">
                    ${escapeHtml(msg.content)}
                </div>
                <div style="margin-top: 6px; padding: 0 4px;">
                    <span style="font-size: 10px; color: var(--text-muted);">${msg.sentAt}</span>
                </div>
            `;
            chatMessages.appendChild(row);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function escapeHtml(text) {
            const div = document.createElement("div");
            div.innerText = text;
            return div.innerHTML;
        }

        window.addEventListener("focus", () => {
             connection.invoke("MarkAsSeen", parseInt(conversationId), currentUserId);
        });
        chatMessages.scrollTop = chatMessages.scrollHeight;
    </script>
}